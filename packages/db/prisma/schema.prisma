enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationTargetType {
  COMPANY
  TRAINER
}

model VerificationRequest {
  id              String                 @id @default(cuid())
  submitterId     String
  targetType      VerificationTargetType
  targetId        String
  status          VerificationStatus     @default(PENDING)
