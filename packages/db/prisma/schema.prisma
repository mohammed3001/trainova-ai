generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// Identity & Access
// =========================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  FINANCE
  SUPPORT
  CONTENT_MANAGER
  ADS_MANAGER
  COMPANY_OWNER
  COMPANY_MEMBER
  TRAINER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  passwordHash       String
  name               String
  role               UserRole
  status             UserStatus @default(ACTIVE)
  locale             String     @default("en")
  /// IANA tz database identifier; falls back to UTC at the formatter when null.
  timezone           String?
  /// ISO 4217 code (e.g. USD, EUR, SAR). Display preference only — payments
  /// remain authoritative in the contract/payout currency.
  currencyPreference String?
  avatarUrl          String?
  emailVerifiedAt    DateTime?
  twoFactorSecret    String?
  lastLoginAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  company                       Company?                  @relation("CompanyOwner")
  companyMembers                CompanyMember[]
  trainerProfile                TrainerProfile?
  sessions                      RefreshToken[]
  applications                  Application[]
  sentMessages                  Message[]                 @relation("MessageSender")
  conversationsIn               ConversationParticipant[]
  authoredReviews               Review[]                  @relation("ReviewAuthor")
  targetReviews                 Review[]                  @relation("ReviewTarget")
  notifications                 Notification[]
  pushSubscriptions             PushSubscription[]
  auditLogs                     AuditLog[]
  emailVerificationTokens       EmailVerificationToken[]
  passwordResetTokens           PasswordResetToken[]
  modelCalls                    ModelCall[]
  stripeConnectAccount          StripeConnectAccount?
  contractsAsTrainer            Contract[]                @relation("ContractTrainer")
  payouts                       Payout[]
  subscriptions                 Subscription[]
  adCampaignsOwned              AdCampaign[]              @relation("AdCampaignOwner")
  adCampaignsReviewed           AdCampaign[]              @relation("AdCampaignReviewer")
  verificationRequestsSubmitted VerificationRequest[]     @relation("VerificationSubmitter")
  verificationRequestsReviewed  VerificationRequest[]     @relation("VerificationReviewer")
  reportsFiled                  Report[]                  @relation("ReportReporter")
  reportsResolved               Report[]                  @relation("ReportResolver")
  emailTemplatesUpdated         EmailTemplate[]           @relation("EmailTemplateUpdatedBy")
  disputesRaised                Dispute[]                 @relation("DisputeRaiser")
  disputesResolved              Dispute[]                 @relation("DisputeResolver")
  taxProfile                    TaxProfile?
  invoicesIssued                Invoice[]                 @relation("InvoiceIssuedBy")
  aiAssistRequests              AiAssistRequest[]
  contractTemplatesCreated      ContractTemplate[]        @relation("ContractTemplateCreator")
  contractDocumentsCreated      ContractDocument[]        @relation("ContractDocumentCreator")
  contractSignatures            ContractSignature[]       @relation("ContractSignatureSigner")
  couponsCreated                Coupon[]                  @relation("CouponCreator")
  couponRedemptions             CouponRedemption[]
  sponsoredPlacementsOwned      SponsoredPlacement[]      @relation("SponsoredPlacementOwner")
  sponsoredPlacementsCreated    SponsoredPlacement[]      @relation("SponsoredPlacementCreator")
  messageTemplates              MessageTemplate[]
  emailCampaignsCreated         EmailCampaign[]           @relation("EmailCampaignCreator")
  emailCampaignSends            EmailCampaignSend[]       @relation("EmailCampaignSendRecipient")
  emailDripSequencesCreated     EmailDripSequence[]       @relation("EmailDripCreator")
  emailDripEnrollments          EmailDripEnrollment[]     @relation("EmailDripEnrollee")
  interviewsScheduledByMe       InterviewMeeting[]        @relation("InterviewScheduler")
  interviewsAsTrainer           InterviewMeeting[]        @relation("InterviewTrainer")
  interviewsCancelledByMe       InterviewMeeting[]        @relation("InterviewCanceller")

  @@index([role, status])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hash      String
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String
  diff       Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

// =========================
// Organizations
// =========================

model Company {
  id               String   @id @default(cuid())
  ownerId          String   @unique
  owner            User     @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name             String
  slug             String   @unique
  logoUrl          String?
  websiteUrl       String?
  country          String?
  industry         String?
  size             String?
  description      String?
  verified         Boolean  @default(false)
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // T9.N — White-label v2.
  // Per-company branding tokens override the global theme on any
  // surface that resolves the active company (owner dashboard,
  // members' dashboards, branded marketing pages). Both colors must
  // be `#RRGGBB` hex; the API validates that. `brandPresetKey`
  // tracks which curated preset was last applied so the UI can show
  // the active preset card without re-deriving from the colors.
  brandPrimaryColor   String?
  brandSecondaryColor String?
  brandPresetKey      BrandingPresetKey?

  // Agency hierarchy: a Company may be designated as the parent
  // "agency" of one or more child companies. Admin operators set the
  // link; the owner of a parent company sees the consolidated list of
  // child companies on their dashboard. SetNull on parent delete so
  // unlinking is a single row update and child rows survive.
  parentAgencyId String?
  parentAgency   Company?  @relation("AgencyChildren", fields: [parentAgencyId], references: [id], onDelete: SetNull)
  childCompanies Company[] @relation("AgencyChildren")

  members          CompanyMember[]
  requests         JobRequest[]
  adCampaigns      AdCampaign[]
  modelConnections ModelConnection[]
  contracts        Contract[]

  @@index([slug])
  @@index([parentAgencyId])
}

enum BrandingPresetKey {
  CORPORATE_BLUE
  MINIMAL_GREEN
  BOLD_PURPLE
  NEUTRAL_GRAY
}

enum CompanyMemberRole {
  OWNER
  ADMIN
  RECRUITER
  VIEWER
}

model CompanyMember {
  id        String            @id @default(cuid())
  companyId String
  userId    String
  role      CompanyMemberRole @default(RECRUITER)
  createdAt DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

// =========================
// Model Registry (T4.A)
// =========================

enum ModelProvider {
  OPENAI_COMPATIBLE
  ANTHROPIC
  BEDROCK
  HUGGINGFACE
  RAW_HTTPS
}

enum ModelConnectionStatus {
  DRAFT
  ACTIVE
  DISABLED
}

/// A company-owned connection to a live model or evaluation endpoint.
/// Credentials are encrypted at rest with the platform key (see
/// `common/crypto.util.ts`) — the raw value never leaves the server.
model ModelConnection {
  id                   String                @id @default(cuid())
  companyId            String
  name                 String
  provider             ModelProvider
  endpointUrl          String?
  modelId              String?
  region               String?
  authKind             String                @default("api_key")
  encryptedCredentials Bytes?
  metadata             Json                  @default("{}")
  status               ModelConnectionStatus @default(DRAFT)
  lastCheckedAt        DateTime?
  lastCheckOk          Boolean?
  lastCheckError       String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?

  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requests   JobRequest[]
  modelCalls ModelCall[]

  @@index([companyId, deletedAt])
}

enum ModelCallOperation {
  CHAT
  COMPLETE
  EMBED
  CUSTOM
}

/// A single proxied call from a trainer against a company-owned model
/// connection. Persisted for RLHF / auditing / billing purposes. The
/// request/response bodies are stored *sanitised* — auth headers are
/// stripped before persistence in the service layer.
model ModelCall {
  id             String             @id @default(cuid())
  connectionId   String
  applicationId  String?
  jobRequestId   String?
  trainerId      String
  operation      ModelCallOperation @default(CHAT)
  requestBody    Json
  responseBody   Json?
  responseStatus Int?
  latencyMs      Int?
  tokensIn       Int?
  tokensOut      Int?
  costCents      Int?
  errorMessage   String?
  createdAt      DateTime           @default(now())

  connection  ModelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  application Application?    @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  jobRequest  JobRequest?     @relation(fields: [jobRequestId], references: [id], onDelete: SetNull)
  trainer     User            @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
  @@index([applicationId, createdAt])
  @@index([trainerId, createdAt])
}

// =========================
// Trainers & Taxonomies
// =========================

model TrainerProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug              String    @unique
  headline          String?
  bio               String?
  country           String?
  languages         String[]  @default([])
  timezone          String?
  hourlyRateMin     Int?
  hourlyRateMax     Int?
  availability      String?
  responseTimeHours Int?
  verified          Boolean   @default(false)
  linkedinUrl       String?
  githubUrl         String?
  websiteUrl        String?
  /// Truthy iff this trainer currently has at least one ACTIVE
  /// `SponsoredPlacement` whose window includes `now()`. Maintained by
  /// `SponsoredService` on activate/expire so listing queries can sort
  /// without fan-out joins. Read-time correctness is enforced by an
  /// additional `endsAt >= now()` filter when boost weights are applied.
  sponsoredUntil    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  skills              TrainerSkill[]
  assets              TrainerAsset[]
  sponsoredPlacements SponsoredPlacement[]

  @@index([slug])
  @@index([sponsoredUntil])
}

model TrainerAsset {
  id         String    @id @default(cuid())
  profileId  String
  kind       String // 'portfolio' | 'certificate'
  objectKey  String    @unique
  url        String
  title      String?
  mimeType   String
  byteLength Int
  order      Int       @default(0)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  profile TrainerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, deletedAt, order])
}

model Skill {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameEn      String
  nameAr      String
  category    String
  description String?
  createdAt   DateTime @default(now())

  trainerSkills TrainerSkill[]
  requestSkills JobRequestSkill[]

  @@index([category])
}

model TrainerSkill {
  id              String  @id @default(cuid())
  profileId       String
  skillId         String
  level           String? // BEGINNER | INTERMEDIATE | ADVANCED | EXPERT
  yearsExperience Int?

  profile TrainerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([profileId, skillId])
}

// =========================
// Job Requests & Applications
// =========================

enum JobRequestStatus {
  DRAFT
  OPEN
  IN_REVIEW
  CLOSED
  ARCHIVED
}

enum WorkType {
  REMOTE
  ONSITE
  HYBRID
}

enum ConfidentialityLevel {
  LOW
  MEDIUM
  HIGH
}

model JobRequest {
  id                   String               @id @default(cuid())
  companyId            String
  modelConnectionId    String?
  slug                 String               @unique
  title                String
  description          String
  objective            String?
  modelFamily          String?
  industry             String?
  languages            String[]             @default([])
  durationDays         Int?
  budgetMin            Int?
  budgetMax            Int?
  currency             String               @default("USD")
  workType             WorkType             @default(REMOTE)
  confidentialityLevel ConfidentialityLevel @default(LOW)
  status               JobRequestStatus     @default(DRAFT)
  featured             Boolean              @default(false)
  /// Mirrors the latest ACTIVE `SponsoredPlacement.endsAt` so list
  /// queries can sort without joining. Maintained by `SponsoredService`.
  sponsoredUntil       DateTime?
  publishedAt          DateTime?
  closedAt             DateTime?
  applicationSchema    Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  modelConnection     ModelConnection?     @relation(fields: [modelConnectionId], references: [id], onDelete: SetNull)
  skills              JobRequestSkill[]
  questions           JobRequestQuestion[]
  applications        Application[]
  tests               Test[]
  conversations       Conversation[]
  modelCalls          ModelCall[]
  sponsoredPlacements SponsoredPlacement[]

  @@index([status, publishedAt])
  @@index([companyId])
  @@index([modelConnectionId])
  @@index([sponsoredUntil])
}

model JobRequestSkill {
  id        String  @id @default(cuid())
  requestId String
  skillId   String
  required  Boolean @default(true)
  minYears  Int?

  request JobRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  skill   Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([requestId, skillId])
}

model JobRequestQuestion {
  id        String   @id @default(cuid())
  requestId String
  prompt    String
  type      String   @default("TEXT") // TEXT | MCQ | MULTI | SCALE
  options   String[] @default([])
  required  Boolean  @default(false)
  order     Int      @default(0)

  request JobRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  TEST_ASSIGNED
  TEST_SUBMITTED
  INTERVIEW
  OFFERED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model Application {
  id                   String            @id @default(cuid())
  requestId            String
  trainerId            String
  status               ApplicationStatus @default(APPLIED)
  coverLetter          String?
  proposedRate         Int?
  proposedTimelineDays Int?
  matchScore           Float?
  answers              Json              @default("{}")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  request     JobRequest              @relation(fields: [requestId], references: [id], onDelete: Cascade)
  trainer     User                    @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  attempts    TestAttempt[]
  attachments ApplicationAttachment[]
  modelCalls  ModelCall[]
  contracts   Contract[]
  interviews  InterviewMeeting[]

  @@unique([requestId, trainerId])
  @@index([trainerId])
}

model ApplicationAttachment {
  id            String    @id @default(cuid())
  applicationId String
  objectKey     String    @unique
  mimeType      String
  byteLength    Int
  title         String?
  scanStatus    String    @default("pending") // pending | clean | infected
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, deletedAt])
}

// =========================
// Tests
// =========================

enum TestScoringMode {
  AUTO
  MANUAL
  HYBRID
}

model Test {
  id           String          @id @default(cuid())
  requestId    String?
  title        String
  description  String?
  timeLimitMin Int?
  passingScore Int             @default(60)
  scoringMode  TestScoringMode @default(AUTO)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  request  JobRequest?   @relation(fields: [requestId], references: [id], onDelete: SetNull)
  tasks    TestTask[]
  attempts TestAttempt[]
}

model TestTask {
  id        String   @id @default(cuid())
  testId    String
  prompt    String
  type      String   @default("MCQ") // MCQ | TEXT | CODE | PROMPT_TUNE | LABEL | LIVE_PROMPT | WORKFLOW
  options   String[] @default([])
  answerKey String? // For MCQ / LABEL
  maxScore  Int      @default(10)
  rubric    Json?
  order     Int      @default(0)

  test      Test               @relation(fields: [testId], references: [id], onDelete: Cascade)
  responses TestTaskResponse[]
}

enum TestAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  EXPIRED
}

model TestAttempt {
  id             String            @id @default(cuid())
  testId         String
  applicationId  String?
  trainerId      String
  startedAt      DateTime          @default(now())
  submittedAt    DateTime?
  status         TestAttemptStatus @default(IN_PROGRESS)
  totalScore     Int?
  scoreBreakdown Json?
  durationSec    Int?
  reviewerNotes  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  test        Test               @relation(fields: [testId], references: [id], onDelete: Cascade)
  application Application?       @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  responses   TestTaskResponse[]

  @@unique([testId, trainerId, applicationId])
  @@index([trainerId])
}

model TestTaskResponse {
  id          String  @id @default(cuid())
  attemptId   String
  taskId      String
  response    Json
  autoScore   Int?
  manualScore Int?
  comments    String?

  attempt TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  task    TestTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([attemptId, taskId])
}

// =========================
// Collaboration
// =========================

model Conversation {
  id         String    @id @default(cuid())
  requestId  String?
  lockedAt   DateTime?
  lockedById String?
  lockReason String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  request      JobRequest?               @relation(fields: [requestId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]
  interviews   InterviewMeeting[]

  @@index([lockedAt])
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  archivedAt     DateTime?
  lastReadAt     DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  type           String    @default("TEXT") // TEXT | FILE | SYSTEM
  redactedAt     DateTime?
  redactedById   String?
  redactReason   String?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([redactedAt])
}

/// Per-user saved message snippets used by the chat composer to insert
/// frequently-used phrasings (NDA reminders, scheduling boilerplate, etc.).
/// Templates are private to the owning user and never shared between
/// participants — the server never references them when sending; they're
/// expanded client-side and posted as a normal `Message`.
model MessageTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, updatedAt])
}

// =========================
// Reviews & Notifications
// =========================

/// A review left by one party of a contract about the other. We persist
/// `contractId` so we can show provenance ("Verified contract review") and
/// enforce one review per author per contract via the unique constraint.
model Review {
  id         String   @id @default(cuid())
  authorId   String
  targetId   String
  contractId String?
  projectRef String?
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  author   User      @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target   User      @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@unique([authorId, contractId])
  @@index([targetId])
  @@index([contractId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

/// Browser Web Push subscription. One row per (user, endpoint) pair —
/// a single user can have multiple devices/browsers each with their own
/// endpoint. Stored encrypted-at-rest by Postgres; the keys are required
/// by the web-push protocol (RFC 8291) to encrypt the payload before it
/// reaches the user agent.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// =========================
// Subscriptions & Ads
// =========================

enum PlanAudience {
  COMPANY
  TRAINER
}

model Plan {
  id            String       @id @default(cuid())
  audience      PlanAudience
  tier          String
  priceMonthly  Int
  priceYearly   Int
  featuresJson  Json
  stripePriceId String?
  createdAt     DateTime     @default(now())
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  planId               String
  status               String    @default("ACTIVE")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?   @unique
  stripeCustomerId     String?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  redemptions CouponRedemption[]

  @@index([userId])
}

// =========================
// Coupons & Promotions (T7.E)
// =========================

enum CouponKind {
  PERCENT
  FIXED
}

enum CouponStatus {
  ACTIVE
  DISABLED
}

enum CouponAudience {
  COMPANY
  TRAINER
  ANY
}

enum CouponAppliesTo {
  SUBSCRIPTION
  MILESTONE
  ANY
}

enum CouponScope {
  SUBSCRIPTION
  MILESTONE
}

/// A redeemable promotional code.
///
/// Discount math (see `computeCouponDiscount` in @trainova/shared):
///   PERCENT — `amountOff` is in basis points (1..10000)
///   FIXED   — `amountOff` is in minor units; `currency` must match
///
/// `stripeCouponId` is required for SUBSCRIPTION redemption — Stripe
/// owns the recurring discount on subscription invoices, so we mirror
/// the coupon there and pass the id through to `subscriptions.create`.
/// MILESTONE redemption is handled in-process: we reduce the
/// PaymentIntent amount and absorb the discount on the platform side.
model Coupon {
  id                 String          @id @default(cuid())
  code               String          @unique
  description        String?
  kind               CouponKind
  amountOff          Int
  currency           String?
  audience           CouponAudience  @default(ANY)
  appliesTo          CouponAppliesTo @default(ANY)
  /// When non-empty, the coupon only applies to subscriptions on these
  /// plans. Ignored for MILESTONE scope.
  planIds            String[]        @default([])
  minAmountMinor     Int?
  maxDiscountMinor   Int?
  validFrom          DateTime?
  validUntil         DateTime?
  maxRedemptions     Int?
  perUserLimit       Int             @default(1)
  redeemedCount      Int             @default(0)
  totalDiscountMinor Int             @default(0)
  status             CouponStatus    @default(ACTIVE)
  stripeCouponId     String?
  createdById        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  createdBy   User?              @relation("CouponCreator", fields: [createdById], references: [id], onDelete: SetNull)
  redemptions CouponRedemption[]

  @@index([status])
  @@index([appliesTo])
  @@index([audience])
}

/// One row per successful application of a coupon. A milestone can be
/// discounted at most once (unique on milestoneId), and a subscription
/// at most once (unique on subscriptionId). Per-user-per-coupon limits
/// are enforced at apply-time inside the same transaction that creates
/// the redemption row.
model CouponRedemption {
  id                  String      @id @default(cuid())
  couponId            String
  userId              String
  scope               CouponScope
  subscriptionId      String?     @unique
  milestoneId         String?     @unique
  originalAmountMinor Int
  discountMinor       Int
  finalAmountMinor    Int
  currency            String
  createdAt           DateTime    @default(now())

  coupon       Coupon        @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  milestone    Milestone?    @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([couponId, userId])
  @@index([userId])
}

// =========================
// Payments & Contracts (T4.C)
// =========================

enum StripeConnectStatus {
  NONE
  PENDING
  ACTIVE
  RESTRICTED
}

/// Per-trainer Stripe Express Connect account used to receive payouts
/// when milestones are released. Onboarding is initiated by the trainer
/// via an Account Link; status is synced from the `account.updated`
/// webhook (see `apps/api/src/payments/webhook.controller.ts`).
model StripeConnectAccount {
  id               String              @id @default(cuid())
  userId           String              @unique
  stripeAccountId  String              @unique
  status           StripeConnectStatus @default(PENDING)
  chargesEnabled   Boolean             @default(false)
  payoutsEnabled   Boolean             @default(false)
  detailsSubmitted Boolean             @default(false)
  country          String?
  defaultCurrency  String?
  lastSyncedAt     DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ContractStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
  DISPUTED
}

enum MilestoneStatus {
  PENDING
  FUNDED
  RELEASED
  REFUNDED
  CANCELLED
}

enum PaymentIntentStatus {
  REQUIRES_PAYMENT_METHOD
  REQUIRES_CONFIRMATION
  REQUIRES_ACTION
  PROCESSING
  REQUIRES_CAPTURE
  SUCCEEDED
  CANCELED
  FAILED
}

enum PayoutStatus {
  PENDING
  IN_TRANSIT
  PAID
  FAILED
  CANCELLED
}

/// A binding agreement between a company and trainer derived from an
/// accepted application. Composed of one or more milestones that move
/// money through escrow (PaymentIntent → held on platform → Transfer to
/// Connect account on release).
model Contract {
  id                  String         @id @default(cuid())
  applicationId       String
  companyId           String
  trainerId           String
  title               String
  description         String?
  currency            String         @default("USD")
  // Pricing breakdown. `totalAmountCents` is the gross amount the buyer
  // pays (subtotal + tax). `subtotalAmountCents` and `taxAmountCents`
  // are derived at contract-creation time from `taxRateBps` resolved via
  // TaxRule + buyer/seller TaxProfile (see TaxService). For pre-T6.C
  // contracts these default to total/0/0 (treated as tax-inclusive).
  totalAmountCents    Int
  subtotalAmountCents Int            @default(0)
  taxRateBps          Int            @default(0) // basis points, 1500 = 15%
  taxAmountCents      Int            @default(0)
  taxLabel            String? // "VAT", "GST", "Sales Tax", etc.
  taxNote             String? // e.g. "Reverse charge — buyer to account for VAT"
  reverseCharge       Boolean        @default(false)
  platformFeeBps      Int            @default(1000) // 10% default commission
  status              ContractStatus @default(DRAFT)
  acceptedAt          DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  application Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trainer     User               @relation("ContractTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  milestones  Milestone[]
  reviews     Review[]
  disputes    Dispute[]
  invoices    Invoice[]
  documents   ContractDocument[]

  @@index([companyId, status])
  @@index([trainerId, status])
  @@index([applicationId])
}

/// Lifecycle of a dispute raised on a contract.
/// OPEN: just raised, awaiting admin triage.
/// UNDER_REVIEW: admin is actively investigating.
/// RESOLVED_FOR_TRAINER / RESOLVED_FOR_COMPANY: admin sided with one party.
/// REJECTED: dispute determined to be without merit.
/// WITHDRAWN: raiser cancelled before admin acted.
enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_FOR_TRAINER
  RESOLVED_FOR_COMPANY
  REJECTED
  WITHDRAWN
}

enum DisputePartyRole {
  COMPANY
  TRAINER
}

/// A formal dispute on a contract. Either party can raise one; admin
/// resolves it. We keep a single OPEN/UNDER_REVIEW row per contract via
/// a partial unique index in code (enforced at the service layer; SQL
/// supports it but Prisma does not surface partial-unique syntax).
model Dispute {
  id           String           @id @default(cuid())
  contractId   String
  raisedById   String
  raisedByRole DisputePartyRole
  reason       String
  description  String?
  evidence     Json?
  status       DisputeStatus    @default(OPEN)
  resolverId   String?
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  raisedBy User     @relation("DisputeRaiser", fields: [raisedById], references: [id], onDelete: Cascade)
  resolver User?    @relation("DisputeResolver", fields: [resolverId], references: [id], onDelete: SetNull)

  @@index([contractId, status])
  @@index([status, createdAt])
  @@index([raisedById])
}

/// An individual payment milestone within a contract. State machine:
/// PENDING → FUNDED (PaymentIntent succeeded, money held on platform)
/// → RELEASED (Transfer to trainer Connect account + Payout queued)
/// OR → REFUNDED (funds returned to company).
model Milestone {
  id             String          @id @default(cuid())
  contractId     String
  title          String
  description    String?
  // `amountCents` is the gross amount Stripe charges the buyer. Tax
  // breakdown is preserved on the milestone so each invoice can be
  // generated independently of the parent contract aggregate.
  amountCents    Int
  subtotalCents  Int             @default(0)
  taxAmountCents Int             @default(0)
  order          Int             @default(0)
  dueDate        DateTime?
  status         MilestoneStatus @default(PENDING)
  fundedAt       DateTime?
  releasedAt     DateTime?
  refundedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  contract         Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  paymentIntents   PaymentIntent[]
  payouts          Payout[]
  invoices         Invoice[]
  couponRedemption CouponRedemption?

  @@index([contractId, order])
}

/// Tracks a Stripe PaymentIntent used to fund a milestone. Mirrors
/// Stripe state via webhooks; idempotent by `stripePaymentIntentId`.
model PaymentIntent {
  id                    String              @id @default(cuid())
  milestoneId           String
  stripePaymentIntentId String              @unique
  clientSecret          String?
  amountCents           Int
  currency              String              @default("USD")
  status                PaymentIntentStatus @default(REQUIRES_PAYMENT_METHOD)
  receiptUrl            String?
  failureMessage        String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
}

/// A transfer from the platform to a trainer's Connect account when a
/// milestone is released. Mirrors Stripe Transfer state via webhooks.
model Payout {
  id               String       @id @default(cuid())
  userId           String
  milestoneId      String?
  stripeTransferId String?      @unique
  stripePayoutId   String?      @unique
  // `amountCents` is what hits the trainer Connect account (gross −
  // platform fee). `grossAmountCents` is the milestone gross before any
  // deductions, kept here so the trainer-side self-billing statement
  // can render fee + tax breakdown without joining back through the
  // milestone (which may have been refunded/cancelled later).
  amountCents      Int
  grossAmountCents Int          @default(0)
  feeAmountCents   Int          @default(0)
  taxAmountCents   Int          @default(0)
  currency         String       @default("USD")
  status           PayoutStatus @default(PENDING)
  failureMessage   String?
  arrivedAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestone Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  invoices  Invoice[]

  @@index([userId, createdAt])
  @@index([milestoneId])
}

/// Idempotency store for incoming Stripe webhook events — every
/// handled event id is recorded so replays become no-ops.
model StripeWebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique
  type          String
  processedAt   DateTime?
  errorMessage  String?
  payload       Json
  createdAt     DateTime  @default(now())

  @@index([type, createdAt])
}

// =========================
// Tax & Invoicing (T6.C)
// =========================

enum TaxKind {
  VAT
  GST
  SALES_TAX
  ZAKAT
  OTHER
}

/// Admin-managed catalog of tax rules keyed by ISO-3166 country code.
/// `b2bReverseCharge=true` means cross-border B2B sales between two
/// VAT-registered businesses zero-rate the tax and add a reverse-charge
/// note instead (typical EU + GCC behaviour). Inactive rules are kept
/// for historical invoices but excluded from new contracts.
model TaxRule {
  id               String   @id @default(cuid())
  countryCode      String   @unique // ISO-3166-1 alpha-2 (e.g. "SA", "DE")
  label            String // Display label, e.g. "VAT", "GST", "Sales Tax"
  kind             TaxKind  @default(VAT)
  rateBps          Int // basis points; 1500 = 15%
  b2bReverseCharge Boolean  @default(false)
  exportZeroRated  Boolean  @default(true) // exports to non-domestic buyers zero-rated
  active           Boolean  @default(true)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([active])
}

enum TaxEntityKind {
  INDIVIDUAL
  BUSINESS
}

/// Per-user tax registration profile. A `taxId` is the VAT/GST/EIN
/// number issued by the local tax authority; presence of a verified id
/// for both parties triggers reverse-charge logic where applicable.
model TaxProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  countryCode   String // ISO-3166-1 alpha-2
  kind          TaxEntityKind @default(INDIVIDUAL)
  legalName     String?
  taxId         String? // VAT registration number, EIN, etc.
  taxIdVerified Boolean       @default(false)
  addressLine1  String?
  addressLine2  String?
  city          String?
  region        String?
  postalCode    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([countryCode])
}

enum InvoiceKind {
  PURCHASE // company-paid milestone invoice (platform → company)
  PAYOUT_STATEMENT // self-billing statement to trainer (platform issues on trainer's behalf)
}

enum InvoiceStatus {
  ISSUED
  PAID
  VOID
}

/// Immutable financial document generated when a milestone is funded
/// (PURCHASE) or released (PAYOUT_STATEMENT). The `number` is a
/// platform-wide sequential identifier formatted as YYYY-NNNNNN; once
/// issued, line items and totals are frozen — corrections require a new
/// invoice with `replacesInvoiceId` set.
model Invoice {
  id                String        @id @default(cuid())
  number            String        @unique // e.g. "2026-000123"
  kind              InvoiceKind
  status            InvoiceStatus @default(ISSUED)
  contractId        String?
  milestoneId       String?
  payoutId          String?
  // Counterparties — denormalized so historical invoices remain
  // accurate even if the underlying TaxProfile is later edited.
  issuerName        String
  issuerCountry     String?
  issuerTaxId       String?
  issuerAddress     String?
  recipientName     String
  recipientCountry  String?
  recipientTaxId    String?
  recipientAddress  String?
  // Money. Values are in `currency` minor units (cents).
  currency          String        @default("USD")
  subtotalCents     Int
  taxRateBps        Int           @default(0)
  taxAmountCents    Int           @default(0)
  totalCents        Int
  taxLabel          String?
  taxNote           String?
  reverseCharge     Boolean       @default(false)
  // Line items as JSON: [{description, quantity, unitCents, totalCents}].
  lineItemsJson     Json
  // Audit + linkage.
  issuedById        String? // admin/system actor; nullable for system-issued
  issuedAt          DateTime      @default(now())
  paidAt            DateTime?
  voidedAt          DateTime?
  replacesInvoiceId String?       @unique // chained corrections
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  contract   Contract?  @relation(fields: [contractId], references: [id], onDelete: SetNull)
  milestone  Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  payout     Payout?    @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  issuedBy   User?      @relation("InvoiceIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)
  replaces   Invoice?   @relation("InvoiceReplaces", fields: [replacesInvoiceId], references: [id], onDelete: SetNull)
  replacedBy Invoice?   @relation("InvoiceReplaces")

  @@index([kind, issuedAt])
  @@index([contractId])
  @@index([milestoneId])
  @@index([payoutId])
}

/// Atomic counter used to mint the `Invoice.number` sequence. A single
/// row keyed by `year` is incremented inside a transaction so two
/// concurrent invoice issuances cannot collide.
model InvoiceCounter {
  year      Int      @id
  lastSeq   Int      @default(0)
  updatedAt DateTime @updatedAt
}

enum AdCampaignStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  ACTIVE
  PAUSED
  REJECTED
  ENDED
}

enum AdPricingModel {
  CPM
  CPC
  FLAT
}

enum AdPlacement {
  HOMEPAGE_HERO
  SIDEBAR_SEARCH
  FEATURED_TRAINER
  FEATURED_COMPANY
  SEARCH_RESULT
  CATEGORY_SPONSOR
  NEWSLETTER
  NATIVE_LISTING
}

enum AdCreativeType {
  BANNER
  SPONSORED_LISTING
  FEATURED_TRAINER
  CATEGORY_SPONSOR
  NATIVE
}

enum AdTopupStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// Why a campaign entered the PAUSED state. Used by creditBudget() to decide
// whether a successful top-up should auto-resume the campaign: only the
// BUDGET_EXHAUSTED auto-pause is safe to reverse, manual admin/owner pauses
// must stay paused until explicitly resumed.
enum AdPauseReason {
  BUDGET_EXHAUSTED
  ADMIN
  OWNER
}

model AdCampaign {
  id                 String           @id @default(cuid())
  ownerId            String
  companyId          String?
  name               String
  pricingModel       AdPricingModel   @default(CPM)
  // Unit prices in the smallest currency unit (cents). Exactly one is required
  // based on `pricingModel`; see `ads.service#create`.
  cpmCents           Int?
  cpcCents           Int?
  flatFeeCents       Int?
  // Running totals — kept on the row so serve() can enforce budget cheaply
  // (no aggregate query per request).
  budgetCents        Int              @default(0)
  // Spent-to-date in whole cents (display-facing, floor of the microcent
  // accumulator) and in microcents (1/1000 of a cent) for lossless sub-cent
  // CPM accrual. CPM charges are fractional per impression, so the sub-cent
  // accumulator prevents Math.floor(cpmCents/1000) from zeroing out for every
  // rate below $10 / 1000 (e.g. cpmCents=500 → 500 microcents/impression).
  spentCents         Int              @default(0)
  spentMicroCents    BigInt           @default(0)
  status             AdCampaignStatus @default(DRAFT)
  pausedReason       AdPauseReason?
  rejectionReason    String?
  reviewedById       String?
  reviewedAt         DateTime?
  targetingCountries String[]         @default([])
  targetingLocales   String[]         @default([])
  targetingSkillIds  String[]         @default([])
  // Hard cap of impressions charged per `sessionHash` within 24h window.
  frequencyCapPerDay Int?
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  owner       User           @relation("AdCampaignOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  reviewer    User?          @relation("AdCampaignReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  company     Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  creatives   AdCreative[]
  impressions AdImpression[]
  clicks      AdClick[]
  topups      AdTopup[]

  @@index([ownerId])
  @@index([status])
  @@index([companyId])
}

model AdCreative {
  id              String         @id @default(cuid())
  campaignId      String
  type            AdCreativeType @default(NATIVE)
  assetUrl        String?
  headline        String
  body            String?
  ctaLabel        String?
  ctaUrl          String
  placements      AdPlacement[]  @default([])
  weight          Int            @default(1)
  isActive        Boolean        @default(true)
  impressionCount Int            @default(0)
  clickCount      Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  campaign    AdCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  impressions AdImpression[]
  clicks      AdClick[]

  @@index([campaignId])
}

model AdImpression {
  id           String      @id @default(cuid())
  creativeId   String
  campaignId   String
  placement    AdPlacement
  locale       String?
  country      String?
  sessionHash  String?
  userId       String?
  chargedCents Int         @default(0)
  createdAt    DateTime    @default(now())

  creative AdCreative @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([creativeId, createdAt])
  @@index([campaignId, createdAt])
  @@index([sessionHash, createdAt])
}

model AdClick {
  id           String      @id @default(cuid())
  creativeId   String
  campaignId   String
  placement    AdPlacement
  locale       String?
  country      String?
  sessionHash  String?
  userId       String?
  chargedCents Int         @default(0)
  createdAt    DateTime    @default(now())

  creative AdCreative @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([creativeId, createdAt])
  @@index([campaignId, createdAt])
}

model AdTopup {
  id                    String        @id @default(cuid())
  campaignId            String
  amountCents           Int
  currency              String        @default("usd")
  stripePaymentIntentId String?       @unique
  status                AdTopupStatus @default(PENDING)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

// =========================
// CMS & Settings
// =========================

model Page {
  id              String   @id @default(cuid())
  slug            String
  locale          String
  title           String
  content         String
  metaTitle       String?
  metaDescription String?
  status          String   @default("PUBLISHED")
  /// Optional tag — e.g. "LEGAL" for /terms, /privacy (hidden from marketing nav).
  kind            String   @default("PAGE")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([slug, locale])
  @@index([kind, status])
}

model Setting {
  key         String   @id
  value       Json
  group       String   @default("general")
  /// When true, the key + value is exposed via `/public/settings` for the marketing
  /// site and client layout (branding, locales, currencies). Admin-only keys (API
  /// credentials, fee basis points, etc.) must keep this `false`.
  isPublic    Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@index([group])
  @@index([isPublic])
}

