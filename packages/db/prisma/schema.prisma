generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// Identity & Access
// =========================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  COMPANY_OWNER
  COMPANY_MEMBER
  TRAINER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model User {
  id               String      @id @default(cuid())
  email            String      @unique
  passwordHash     String
  name             String
  role             UserRole
  status           UserStatus  @default(ACTIVE)
  locale           String      @default("en")
  emailVerifiedAt  DateTime?
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  company          Company?           @relation("CompanyOwner")
  companyMembers   CompanyMember[]
  trainerProfile   TrainerProfile?
  sessions         RefreshToken[]
  applications     Application[]
  sentMessages     Message[]          @relation("MessageSender")
  conversationsIn  ConversationParticipant[]
  authoredReviews  Review[]           @relation("ReviewAuthor")
  targetReviews    Review[]           @relation("ReviewTarget")
  notifications    Notification[]
  auditLogs        AuditLog[]

  @@index([role, status])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hash       String
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String
  diff       Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

// =========================
// Organizations
// =========================

model Company {
  id               String   @id @default(cuid())
  ownerId          String   @unique
  owner            User     @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name             String
  slug             String   @unique
  logoUrl          String?
  websiteUrl       String?
  country          String?
  industry         String?
  size             String?
  description      String?
  verified         Boolean  @default(false)
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members    CompanyMember[]
  requests   JobRequest[]
  adCampaigns AdCampaign[]

  @@index([slug])
}

enum CompanyMemberRole {
  OWNER
  ADMIN
  RECRUITER
  VIEWER
}

model CompanyMember {
  id        String            @id @default(cuid())
  companyId String
  userId    String
  role      CompanyMemberRole @default(RECRUITER)
  createdAt DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

// =========================
// Trainers & Taxonomies
// =========================

model TrainerProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug             String   @unique
  headline         String?
  bio              String?
  country          String?
  languages        String[] @default([])
  timezone         String?
  hourlyRateMin    Int?
  hourlyRateMax    Int?
  availability     String?
  responseTimeHours Int?
  verified         Boolean  @default(false)
  linkedinUrl      String?
  githubUrl        String?
  websiteUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  skills TrainerSkill[]

  @@index([slug])
}

model Skill {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameEn      String
  nameAr      String
  category    String
  description String?
  createdAt   DateTime @default(now())

  trainerSkills TrainerSkill[]
  requestSkills JobRequestSkill[]

  @@index([category])
}

model TrainerSkill {
  id              String  @id @default(cuid())
  profileId       String
  skillId         String
  level           String? // BEGINNER | INTERMEDIATE | ADVANCED | EXPERT
  yearsExperience Int?

  profile TrainerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([profileId, skillId])
}

// =========================
// Job Requests & Applications
// =========================

enum JobRequestStatus {
  DRAFT
  OPEN
  IN_REVIEW
  CLOSED
  ARCHIVED
}

enum WorkType {
  REMOTE
  ONSITE
  HYBRID
}

enum ConfidentialityLevel {
  LOW
  MEDIUM
  HIGH
}

model JobRequest {
  id                   String               @id @default(cuid())
  companyId            String
  slug                 String               @unique
  title                String
  description          String
  objective            String?
  modelFamily          String?
  industry             String?
  languages            String[]             @default([])
  durationDays         Int?
  budgetMin            Int?
  budgetMax            Int?
  currency             String               @default("USD")
  workType             WorkType             @default(REMOTE)
  confidentialityLevel ConfidentialityLevel @default(LOW)
  status               JobRequestStatus     @default(DRAFT)
  featured             Boolean              @default(false)
  publishedAt          DateTime?
  closedAt             DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skills        JobRequestSkill[]
  questions     JobRequestQuestion[]
  applications  Application[]
  tests         Test[]
  conversations Conversation[]

  @@index([status, publishedAt])
  @@index([companyId])
}

model JobRequestSkill {
  id         String  @id @default(cuid())
  requestId  String
  skillId    String
  required   Boolean @default(true)
  minYears   Int?

  request JobRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  skill   Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([requestId, skillId])
}

model JobRequestQuestion {
  id        String  @id @default(cuid())
  requestId String
  prompt    String
  type      String  @default("TEXT") // TEXT | MCQ | MULTI | SCALE
  options   String[] @default([])
  required  Boolean @default(false)
  order     Int     @default(0)

  request JobRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  TEST_ASSIGNED
  TEST_SUBMITTED
  INTERVIEW
  OFFERED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model Application {
  id                   String            @id @default(cuid())
  requestId            String
  trainerId            String
  status               ApplicationStatus @default(APPLIED)
  coverLetter          String?
  proposedRate         Int?
  proposedTimelineDays Int?
  matchScore           Float?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  request  JobRequest     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  trainer  User           @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  attempts TestAttempt[]

  @@unique([requestId, trainerId])
  @@index([trainerId])
}

// =========================
// Tests
// =========================

enum TestScoringMode {
  AUTO
  MANUAL
  HYBRID
}

model Test {
  id            String          @id @default(cuid())
  requestId     String?
  title         String
  description   String?
  timeLimitMin  Int?
  passingScore  Int             @default(60)
  scoringMode   TestScoringMode @default(AUTO)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  request  JobRequest?   @relation(fields: [requestId], references: [id], onDelete: SetNull)
  tasks    TestTask[]
  attempts TestAttempt[]
}

model TestTask {
  id        String  @id @default(cuid())
  testId    String
  prompt    String
  type      String  @default("MCQ") // MCQ | TEXT | CODE | PROMPT_TUNE | LABEL | LIVE_PROMPT | WORKFLOW
  options   String[] @default([])
  answerKey String?   // For MCQ / LABEL
  maxScore  Int      @default(10)
  rubric    Json?
  order     Int      @default(0)

  test      Test               @relation(fields: [testId], references: [id], onDelete: Cascade)
  responses TestTaskResponse[]
}

enum TestAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  EXPIRED
}

model TestAttempt {
  id              String            @id @default(cuid())
  testId          String
  applicationId   String?
  trainerId       String
  startedAt       DateTime          @default(now())
  submittedAt     DateTime?
  status          TestAttemptStatus @default(IN_PROGRESS)
  totalScore      Int?
  scoreBreakdown  Json?
  durationSec     Int?
  reviewerNotes   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  test        Test              @relation(fields: [testId], references: [id], onDelete: Cascade)
  application Application?      @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  responses   TestTaskResponse[]

  @@index([trainerId])
}

model TestTaskResponse {
  id           String  @id @default(cuid())
  attemptId    String
  taskId       String
  response     Json
  autoScore    Int?
  manualScore  Int?
  comments     String?

  attempt TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  task    TestTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([attemptId, taskId])
}

// =========================
// Collaboration
// =========================

model Conversation {
  id         String   @id @default(cuid())
  requestId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  request      JobRequest?               @relation(fields: [requestId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id              String   @id @default(cuid())
  conversationId  String
  userId          String
  archivedAt      DateTime?
  lastReadAt      DateTime?
  createdAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  type           String   @default("TEXT") // TEXT | FILE | SYSTEM
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// =========================
// Reviews & Notifications
// =========================

model Review {
  id          String   @id @default(cuid())
  authorId    String
  targetId    String
  projectRef  String?
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  author User @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target User @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([targetId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

// =========================
// Subscriptions & Ads
// =========================

enum PlanAudience {
  COMPANY
  TRAINER
}

model Plan {
  id             String       @id @default(cuid())
  audience       PlanAudience
  tier           String
  priceMonthly   Int
  priceYearly    Int
  featuresJson   Json
  stripePriceId  String?
  createdAt      DateTime     @default(now())
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  planId               String
  status               String    @default("ACTIVE")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
}

model AdCampaign {
  id           String    @id @default(cuid())
  companyId    String?
  name         String
  budget       Int
  startDate    DateTime?
  endDate      DateTime?
  status       String    @default("ACTIVE")
  targeting    Json?
  createdAt    DateTime  @default(now())

  company    Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  creatives  AdCreative[]
}

model AdCreative {
  id          String   @id @default(cuid())
  campaignId  String
  type        String   // BANNER | SPONSORED_LISTING | FEATURED_TRAINER | CATEGORY_SPONSOR
  assetUrl    String?
  headline    String
  body        String?
  ctaUrl      String?
  placements  String[] @default([])
  createdAt   DateTime @default(now())

  campaign    AdCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  impressions AdImpression[]
  clicks      AdClick[]
}

model AdImpression {
  id         String   @id @default(cuid())
  creativeId String
  placement  String?
  meta       Json?
  createdAt  DateTime @default(now())

  creative AdCreative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@index([creativeId])
}

model AdClick {
  id         String   @id @default(cuid())
  creativeId String
  placement  String?
  meta       Json?
  createdAt  DateTime @default(now())

  creative AdCreative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@index([creativeId])
}

// =========================
// CMS & Settings
// =========================

model Page {
  id              String   @id @default(cuid())
  slug            String
  locale          String
  title           String
  content         String
  metaTitle       String?
  metaDescription String?
  status          String   @default("PUBLISHED")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([slug, locale])
}

model Setting {
  key       String @id
  value     Json
  group     String @default("general")
  updatedAt DateTime @updatedAt
}
