enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Category {
  id            String    @id @default(cuid())
  slug          String    @unique
  nameEn        String
  nameAr        String
  descriptionEn String?
  descriptionAr String?
  order         Int       @default(0)
  articles      Article[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Article {
  id              String        @id @default(cuid())
  slug            String
  locale          String
  title           String
  excerpt         String?
  content         String
  coverUrl        String?
  metaTitle       String?
  metaDescription String?
  status          ArticleStatus @default(DRAFT)
  publishedAt     DateTime?
  categoryId      String?
  category        Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  authorId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([slug, locale])
  @@index([status, publishedAt])
  @@index([categoryId])
}

model FaqEntry {
  id        String   @id @default(cuid())
  locale    String
  section   String   @default("GENERAL")
  question  String
  answer    String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale, section, order])
  @@index([published])
}

model FeatureFlag {
  key         String   @id
  description String?
  enabled     Boolean  @default(false)
  /// JSON payload with optional variants / rollout percentage / audiences.
  payload     Json?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

// =========================
