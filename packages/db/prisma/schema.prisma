enum ReportTargetType {
  USER
  COMPANY
  TRAINER
  REQUEST
  APPLICATION
  MESSAGE
  CONVERSATION
  REVIEW
  TEST
  OTHER
}

enum ReportCategory {
  SPAM
  HARASSMENT
  INAPPROPRIATE
  FRAUD
  IMPERSONATION
  COPYRIGHT
  SAFETY
  OTHER
}

enum ReportStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  DISMISSED
}

enum ReportResolution {
  NO_ACTION
  WARNING_ISSUED
  CONTENT_REMOVED
  USER_SUSPENDED
  USER_BANNED
  ESCALATED
}

model Report {
  id            String            @id @default(cuid())
