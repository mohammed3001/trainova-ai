/// Admin-editable email templates. The in-code templates in
/// `apps/api/src/email/templates/*` remain as fallback so the app always
/// has content even before the DB is seeded. On every email send, the
/// service looks up `(key, locale)` here first; if found and enabled, the
/// DB row wins and `{{variables}}` are interpolated against the call-site
/// params. Otherwise we fall back to the built-in template.
///
/// `key` matches the enum in @trainova/shared (VERIFY_EMAIL, RESET_PASSWORD,
/// WELCOME, TEST_ASSIGNED, …) and `locale` is 'en' or 'ar'. Composite unique
/// on (key, locale) enforces exactly one row per translation.
model EmailTemplate {
  id          String   @id @default(cuid())
  key         String
  locale      String
  subject     String
  bodyHtml    String   @db.Text
  bodyText    String   @db.Text
  variables   Json     @default("[]")
  enabled     Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("EmailTemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([key, locale])
  @@index([key])
}

/// FX rate snapshot used to convert one currency to another for *display*
/// purposes. Authoritative monetary records stay in the contract/payout's
/// own currency. Rates are sourced from the ECB's Frankfurter mirror
/// (https://api.frankfurter.app), which is free, key-less, and updates
/// daily on TARGET2 settlement days. We always store rates anchored to
/// USD so all formatters can do exactly two lookups (from→USD, USD→to)
/// and avoid an N×N rate matrix.
///
/// Composite unique on (base, quote, fetchedAt::date) is enforced via a
/// partial unique index in the migration; Prisma stores the latest rate
/// per pair on the lookup index `(base, quote, fetchedAt desc)`.
model ExchangeRate {
  id        String   @id @default(cuid())
  base      String // ISO 4217 (always "USD" for now)
  quote     String // ISO 4217 (e.g. "EUR", "SAR", "GBP")
  rate      Decimal  @db.Decimal(18, 8)
  source    String   @default("frankfurter")
  fetchedAt DateTime @default(now())

  @@index([base, quote, fetchedAt(sort: Desc)])
}

// =========================
// AI Assistant (T7.A)
// =========================

/// Discriminator for the type of LLM-backed task the platform performs on
/// behalf of a user. Each kind has a dedicated controller endpoint with a
/// typed input/output zod schema in `packages/shared/src/ai-assist.ts`.
enum AiAssistKind {
  REQUEST_DRAFT // Help a company draft a JobRequest from a brief.
  APPLICATION_SCREEN // Score + summarize an Application against a JobRequest.
  CHAT_SUMMARY // Summarize a Conversation up to a given cutoff message.
  CHAT_TASKS // Extract action items from a Conversation.
  SEO_META // Generate SEO title/description for a Page or Article.
  EMAIL_DRAFT // Draft transactional/marketing email copy.
  PRICING_SUGGEST // Suggest contract pricing range for a JobRequest.
  TEST_GEN // Generate Test tasks from a JobRequest description.
  PROFILE_OPT // Suggest improvements to a TrainerProfile bio + headline.
}

enum AiAssistStatus {
  PENDING
  SUCCEEDED
  FAILED
}

/// Persistent log of every AI Assistant invocation. Used for: (a) cost
/// accounting, (b) abuse detection, (c) showing recent generations to the
/// user, and (d) replay/audit. The full prompt (`inputJson`) and model
/// output (`outputJson`) are stored verbatim — keep PII minimization at
/// the call site.
model AiAssistRequest {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind              AiAssistKind
  status            AiAssistStatus @default(PENDING)
  modelUsed         String? // e.g. "gpt-4o-mini"
  provider          String? // "openai" | "mock" — what actually ran
  inputJson         Json
  outputJson        Json?
  error             String?
  promptTokens      Int            @default(0)
  completionTokens  Int            @default(0)
  /// Cost expressed in micro-cents (1e-6 USD cent) for sub-cent precision.
  costMicros        Int            @default(0)
  durationMs        Int?
  /// Soft reference (no FK) to the entity this generation is attached to.
  /// Allowed values mirror `AiAssistKind` semantics: 'JobRequest',
  /// 'Application', 'Conversation', 'Page', 'Article', 'EmailTemplate',
  /// 'TrainerProfile', 'Test'. Nullable for kinds without a context entity.
  contextEntityType String?
  contextEntityId   String?
  ip                String?
  createdAt         DateTime       @default(now())

  @@index([userId, kind, createdAt(sort: Desc)])
  @@index([contextEntityType, contextEntityId])
  @@index([status])
}

/// Public contact-form submissions from the marketing pages.
/// Stored so the admin can audit / reply outside of email, and so we can
/// do anti-spam analytics later. No PII beyond what the visitor typed.
enum ContactSubmissionStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

enum ContactSubmissionTopic {
  GENERAL
  SALES
  SUPPORT
  PRESS
  PARTNERSHIP
  ADVERTISING
}

// =========================
// Sponsored search placements (Tier 7.G)
// =========================

enum SponsoredPlacementKind {
  TRAINER
  JOB_REQUEST
}

enum SponsoredPlacementStatus {
  /// Editable, not visible publicly. Self-paid placements move out of
  /// `DRAFT` once the company/trainer kicks off Stripe checkout.
  DRAFT
  /// Self-paid placement that has a PaymentIntent created but not yet
  /// captured. Becomes `ACTIVE` on `payment_intent.succeeded` webhook.
  PENDING_PAYMENT
  /// Currently boosting search results for `trainerProfileId` /
  /// `jobRequestId`. Read-time queries also enforce `endsAt >= now()`.
  ACTIVE
  /// Owner-initiated pause. Does not refund.
  PAUSED
  /// Past `endsAt`. Set lazily by `SponsoredService.expireDue()`.
  EXPIRED
  /// Admin rejected (e.g. policy / payment dispute). Refund handled
  /// out-of-band.
  REJECTED
}

enum SponsoredPlacementSource {
  /// Granted by an admin. No charge.
  ADMIN
  /// Purchased by the owner via Stripe.
  SELF_PAID
}

model SponsoredPlacement {
  id                    String                   @id @default(cuid())
  kind                  SponsoredPlacementKind
  /// Set when `kind = TRAINER`.
  trainerProfileId      String?
  /// Set when `kind = JOB_REQUEST`.
  jobRequestId          String?
  /// User who benefits from / pays for the placement (the trainer for
  /// `kind=TRAINER`, the company owner / admin issuer for `JOB_REQUEST`).
  ownerId               String
  /// Acting principal: admin id for `ADMIN` source, owner id for
  /// `SELF_PAID`. Captured for the audit trail so admin grants are
  /// attributable.
  createdById           String
  source                SponsoredPlacementSource @default(SELF_PAID)
  status                SponsoredPlacementStatus @default(DRAFT)
  /// Additive boost (in matching-score points) applied to organic
  /// scores. Hard-capped to `[1, 50]` by the service so sponsorship can
  /// never push a low-quality match past a high-quality unsponsored one
  /// by more than half the scale.
  weight                Int                      @default(20)
  startsAt              DateTime                 @default(now())
  endsAt                DateTime
  pricedCents           Int                      @default(0)
  currency              String                   @default("USD")
  stripePaymentIntentId String?                  @unique
  notes                 String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  owner          User            @relation("SponsoredPlacementOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdBy      User            @relation("SponsoredPlacementCreator", fields: [createdById], references: [id], onDelete: Cascade)
  trainerProfile TrainerProfile? @relation(fields: [trainerProfileId], references: [id], onDelete: Cascade)
  jobRequest     JobRequest?     @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)

  @@index([kind, status, endsAt])
  @@index([ownerId])
  @@index([trainerProfileId, status])
  @@index([jobRequestId, status])
}

model ContactSubmission {
  id        String                  @id @default(cuid())
  name      String
  email     String
  topic     ContactSubmissionTopic  @default(GENERAL)
  /// Optional company / organisation name.
  company   String?
  message   String
  /// IP, captured server-side from the trusted proxy header.
  ip        String?
  /// User agent string at submission time.
  userAgent String?
  /// Locale of the page the visitor was on when they submitted.
  locale    String?
  status    ContactSubmissionStatus @default(NEW)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([email])
}

// -----------------------------------------------------------------------------
// T7.C — E-Signature: ContractTemplate (NDA/MSA/SOW), ContractDocument
// (frozen instance per Contract), ContractSignature (one row per required
// signer). Templates are authored by Admins; Companies generate documents
// from a template against a specific Contract; both COMPANY and TRAINER
// must sign. The signed payload is hashed (SHA-256 over the frozen Markdown
// body + signer + typed name + ISO timestamp) so any later mutation can be
// detected.
// -----------------------------------------------------------------------------

enum ContractDocumentKind {
  NDA
  MSA
  SOW
  CUSTOM
}

enum ContractTemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContractDocumentStatus {
  DRAFT
  AWAITING_SIGNATURES
  PARTIALLY_SIGNED
  FULLY_SIGNED
  CANCELLED
  EXPIRED
}

enum SignatureRole {
  COMPANY
  TRAINER
}

enum SignatureStatus {
  PENDING
  SIGNED
  DECLINED
}

/// Reusable Markdown contract templates authored by Admins. Variables are
/// declared once and resolved at document-generation time. `slug` is unique
/// across all templates; `locale` lets a single kind have multiple
/// translations (EN/AR/FR/ES).
model ContractTemplate {
  id           String                 @id @default(cuid())
  kind         ContractDocumentKind
  slug         String                 @unique
  name         String
  description  String?
  bodyMarkdown String
  locale       String                 @default("EN")
  /// JSON array: [{ key: "companyName", label: "Company name", required: true, default?: string }]
  variables    Json
  status       ContractTemplateStatus @default(DRAFT)
  createdById  String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  createdBy User               @relation("ContractTemplateCreator", fields: [createdById], references: [id], onDelete: Restrict)
  documents ContractDocument[]

  @@index([kind, status])
  @@index([locale])
}

/// A frozen, contract-bound instance of a template (or ad-hoc Markdown).
/// `bodyMarkdown` is captured at creation time; any subsequent template
/// edits do NOT mutate already-issued documents. `bodyHash` is the SHA-256
/// over `bodyMarkdown` and is referenced from every signature row.
model ContractDocument {
  id           String                 @id @default(cuid())
  contractId   String
  templateId   String?
  kind         ContractDocumentKind
  title        String
  bodyMarkdown String
  bodyHash     String
  status       ContractDocumentStatus @default(DRAFT)
  createdById  String
  expiresAt    DateTime?
  signedAt     DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  contract   Contract            @relation(fields: [contractId], references: [id], onDelete: Cascade)
  template   ContractTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy  User                @relation("ContractDocumentCreator", fields: [createdById], references: [id], onDelete: Restrict)
  signatures ContractSignature[]

  @@index([contractId])
  @@index([status])
  @@index([templateId])
}

/// One row per required signer per document. Unique on (documentId, role)
/// so a single document has at most one COMPANY + one TRAINER signature row.
model ContractSignature {
  id            String          @id @default(cuid())
  documentId    String
  signerId      String
  role          SignatureRole
  status        SignatureStatus @default(PENDING)
  signedName    String?
  intent        String?
  signatureHash String?
  ipAddress     String?
  userAgent     String?
  signedAt      DateTime?
  declinedAt    DateTime?
  declineReason String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  document ContractDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signer   User             @relation("ContractSignatureSigner", fields: [signerId], references: [id], onDelete: Restrict)

  @@unique([documentId, role])
  @@index([signerId])
}

// =========================
// Email Marketing (T7.I) — Campaigns + Drip sequences
// =========================
//
// Campaigns are admin-authored marketing emails (one-shot broadcasts).
// Drip sequences are ordered, delay-based steps a user is enrolled in.
// Both reuse the existing EmailService transport (Resend / console). Sends
// are tracked per-recipient for idempotency: each (campaign,user) pair has
// a unique row that flips PENDING -> SENT/FAILED, so a retry on the cron
// pass never double-sends.

enum EmailCampaignKind {
  BROADCAST
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
  FAILED
}

enum EmailCampaignSendStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum EmailDripTrigger {
  USER_REGISTERED
  TRAINER_PROFILE_INCOMPLETE
  COMPANY_FIRST_REQUEST_PENDING
  MANUAL
}

model EmailCampaign {
  id           String              @id @default(cuid())
  name         String
  kind         EmailCampaignKind   @default(BROADCAST)
  status       EmailCampaignStatus @default(DRAFT)
  /// 'en' | 'ar' | 'fr' | 'es'
  locale       String              @default("en")
  subject      String
  bodyHtml     String              @db.Text
  bodyText     String              @db.Text
  /// Structured segment filter; resolved server-side to a User[] at send time.
  segmentJson  Json
  scheduledFor DateTime?
  startedAt    DateTime?
  finishedAt   DateTime?
  sentCount    Int                 @default(0)
  failedCount  Int                 @default(0)
  createdById  String
  createdBy    User                @relation("EmailCampaignCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  sends EmailCampaignSend[]

  @@index([status, scheduledFor])
}

model EmailCampaignSend {
  id         String                  @id @default(cuid())
  campaignId String
  campaign   EmailCampaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String
  user       User                    @relation("EmailCampaignSendRecipient", fields: [userId], references: [id], onDelete: Cascade)
  status     EmailCampaignSendStatus @default(PENDING)
  sentAt     DateTime?
  error      String?

  @@unique([campaignId, userId])
  @@index([status, campaignId])
}

model EmailDripSequence {
  id          String           @id @default(cuid())
  name        String
  /// Stable string used by hooks to enroll users into this sequence.
  slug        String           @unique
  trigger     EmailDripTrigger @default(MANUAL)
  enabled     Boolean          @default(true)
  createdById String
  createdBy   User             @relation("EmailDripCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  steps       EmailDripStep[]
  enrollments EmailDripEnrollment[]

  @@index([trigger, enabled])
}

model EmailDripStep {
  id           String            @id @default(cuid())
  sequenceId   String
  sequence     EmailDripSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  /// 0-based, contiguous within a sequence.
  order        Int
  /// Cumulative delay since enrollment time, in minutes.
  delayMinutes Int
  /// 'en' | 'ar' | 'fr' | 'es'
  locale       String            @default("en")
  subject      String
  bodyHtml     String            @db.Text
  bodyText     String            @db.Text

  @@unique([sequenceId, order])
}

model EmailDripEnrollment {
  id             String            @id @default(cuid())
  sequenceId     String
  sequence       EmailDripSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  userId         String
  user           User              @relation("EmailDripEnrollee", fields: [userId], references: [id], onDelete: Cascade)
  currentStepIdx Int               @default(0)
  nextRunAt      DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([sequenceId, userId])
  @@index([nextRunAt, completedAt, cancelledAt])
}

// =========================
// Interview scheduling (T8.C)
// =========================

enum InterviewStatus {
  /// Active, in-the-future meeting that has not yet happened.
  SCHEDULED
  /// Either party cancelled before it took place. Final.
  CANCELLED
  /// Marked completed by the company after it took place. Final.
  COMPLETED
}

/// A scheduled interview between a company-side user and a trainer,
/// always anchored to an existing chat conversation. Optionally linked
/// to a specific Application so it surfaces on the application detail
/// page. We keep the conversation as the source of truth for who can
/// participate (both rows of `ConversationParticipant` already cover
/// auth), and limit creation to the company side of that chat.
///
/// Reschedules are modeled as cancel-and-create with `rescheduledFromId`
/// linking the new meeting to the cancelled one — keeping a single
/// status enum per row keeps queries simple ("show me my upcoming
/// interviews" is just `status = SCHEDULED`).
model InterviewMeeting {
  id                String          @id @default(cuid())
  conversationId    String
  applicationId     String?
  scheduledById     String
  trainerId         String
  /// UTC instant the meeting starts. The originating user's IANA tz
  /// is stored separately so the chat banner / list page can format
  /// for either participant without ambiguity.
  scheduledAt       DateTime
  durationMin       Int             @default(30)
  /// IANA tz identifier of the user who scheduled the meeting. The
  /// trainer's view formats with their own profile timezone — this
  /// field is informational ("scheduled by NY office") only.
  timezone          String
  /// Optional external join URL (Zoom / Meet / Teams). We deliberately
  /// don't host a video provider ourselves at this tier — see T8.B.
  meetingUrl        String?
  agenda            String?
  /// Free-text notes visible to *both* participants.
  notes             String?
  status            InterviewStatus @default(SCHEDULED)
  cancelReason      String?
  cancelledAt       DateTime?
  cancelledById     String?
  /// Set when this row was created as a reschedule of a cancelled
  /// meeting. The cancelled row stays in the table for audit.
  rescheduledFromId String?         @unique
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  conversation    Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  application     Application?      @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  scheduledBy     User              @relation("InterviewScheduler", fields: [scheduledById], references: [id], onDelete: Cascade)
  trainer         User              @relation("InterviewTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  cancelledBy     User?             @relation("InterviewCanceller", fields: [cancelledById], references: [id])
  rescheduledFrom InterviewMeeting? @relation("InterviewReschedule", fields: [rescheduledFromId], references: [id])
  rescheduledTo   InterviewMeeting? @relation("InterviewReschedule")

  @@index([conversationId, scheduledAt])
  @@index([trainerId, status, scheduledAt])
  @@index([scheduledById, status, scheduledAt])
  @@index([status, scheduledAt])
}
