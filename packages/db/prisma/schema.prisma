generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// Identity & Access
// =========================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  COMPANY_OWNER
  COMPANY_MEMBER
  TRAINER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  passwordHash       String
  name               String
  role               UserRole
  status             UserStatus @default(ACTIVE)
  locale             String     @default("en")
  /// IANA tz database identifier; falls back to UTC at the formatter when null.
  timezone           String?
  /// ISO 4217 code (e.g. USD, EUR, SAR). Display preference only — payments
  /// remain authoritative in the contract/payout currency.
  currencyPreference String?
  avatarUrl          String?
  emailVerifiedAt    DateTime?
  twoFactorSecret    String?
  lastLoginAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  company                       Company?                  @relation("CompanyOwner")
  companyMembers                CompanyMember[]
  trainerProfile                TrainerProfile?
  sessions                      RefreshToken[]
  applications                  Application[]
  sentMessages                  Message[]                 @relation("MessageSender")
  conversationsIn               ConversationParticipant[]
  authoredReviews               Review[]                  @relation("ReviewAuthor")
  targetReviews                 Review[]                  @relation("ReviewTarget")
  notifications                 Notification[]
  auditLogs                     AuditLog[]
  emailVerificationTokens       EmailVerificationToken[]
  passwordResetTokens           PasswordResetToken[]
  modelCalls                    ModelCall[]
  stripeConnectAccount          StripeConnectAccount?
  contractsAsTrainer            Contract[]                @relation("ContractTrainer")
  payouts                       Payout[]
  subscriptions                 Subscription[]
  adCampaignsOwned              AdCampaign[]              @relation("AdCampaignOwner")
  adCampaignsReviewed           AdCampaign[]              @relation("AdCampaignReviewer")
  verificationRequestsSubmitted VerificationRequest[]     @relation("VerificationSubmitter")
  verificationRequestsReviewed  VerificationRequest[]     @relation("VerificationReviewer")
  reportsFiled                  Report[]                  @relation("ReportReporter")
  reportsResolved               Report[]                  @relation("ReportResolver")
  emailTemplatesUpdated         EmailTemplate[]           @relation("EmailTemplateUpdatedBy")
  disputesRaised                Dispute[]                 @relation("DisputeRaiser")
  disputesResolved              Dispute[]                 @relation("DisputeResolver")

  @@index([role, status])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hash      String
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String
  diff       Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

// =========================
// Organizations
// =========================

model Company {
  id               String   @id @default(cuid())
  ownerId          String   @unique
  owner            User     @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name             String
  slug             String   @unique
  logoUrl          String?
  websiteUrl       String?
  country          String?
  industry         String?
  size             String?
  description      String?
  verified         Boolean  @default(false)
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members          CompanyMember[]
  requests         JobRequest[]
  adCampaigns      AdCampaign[]
  modelConnections ModelConnection[]
  contracts        Contract[]

  @@index([slug])
}

enum CompanyMemberRole {
  OWNER
  ADMIN
  RECRUITER
  VIEWER
}

model CompanyMember {
  id        String            @id @default(cuid())
  companyId String
  userId    String
  role      CompanyMemberRole @default(RECRUITER)
  createdAt DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

// =========================
// Model Registry (T4.A)
// =========================

enum ModelProvider {
  OPENAI_COMPATIBLE
  ANTHROPIC
  BEDROCK
  HUGGINGFACE
  RAW_HTTPS
}

enum ModelConnectionStatus {
  DRAFT
  ACTIVE
  DISABLED
}

/// A company-owned connection to a live model or evaluation endpoint.
/// Credentials are encrypted at rest with the platform key (see
/// `common/crypto.util.ts`) — the raw value never leaves the server.
model ModelConnection {
  id                   String                @id @default(cuid())
  companyId            String
  name                 String
  provider             ModelProvider
  endpointUrl          String?
  modelId              String?
  region               String?
  authKind             String                @default("api_key")
  encryptedCredentials Bytes?
  metadata             Json                  @default("{}")
  status               ModelConnectionStatus @default(DRAFT)
  lastCheckedAt        DateTime?
  lastCheckOk          Boolean?
  lastCheckError       String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?

  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requests   JobRequest[]
  modelCalls ModelCall[]

  @@index([companyId, deletedAt])
}

enum ModelCallOperation {
  CHAT
  COMPLETE
  EMBED
  CUSTOM
}

/// A single proxied call from a trainer against a company-owned model
/// connection. Persisted for RLHF / auditing / billing purposes. The
/// request/response bodies are stored *sanitised* — auth headers are
/// stripped before persistence in the service layer.
model ModelCall {
  id             String             @id @default(cuid())
  connectionId   String
  applicationId  String?
  jobRequestId   String?
  trainerId      String
  operation      ModelCallOperation @default(CHAT)
  requestBody    Json
  responseBody   Json?
  responseStatus Int?
  latencyMs      Int?
  tokensIn       Int?
  tokensOut      Int?
  costCents      Int?
  errorMessage   String?
  createdAt      DateTime           @default(now())

  connection  ModelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  application Application?    @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  jobRequest  JobRequest?     @relation(fields: [jobRequestId], references: [id], onDelete: SetNull)
  trainer     User            @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
  @@index([applicationId, createdAt])
  @@index([trainerId, createdAt])
}

// =========================
// Trainers & Taxonomies
// =========================

model TrainerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug              String   @unique
  headline          String?
  bio               String?
  country           String?
  languages         String[] @default([])
  timezone          String?
  hourlyRateMin     Int?
  hourlyRateMax     Int?
  availability      String?
  responseTimeHours Int?
  verified          Boolean  @default(false)
  linkedinUrl       String?
  githubUrl         String?
  websiteUrl        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  skills TrainerSkill[]
  assets TrainerAsset[]

  @@index([slug])
}

model TrainerAsset {
  id         String    @id @default(cuid())
  profileId  String
  kind       String // 'portfolio' | 'certificate'
  objectKey  String    @unique
  url        String
  title      String?
  mimeType   String
  byteLength Int
  order      Int       @default(0)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  profile TrainerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, deletedAt, order])
}

model Skill {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameEn      String
  nameAr      String
  category    String
  description String?
  createdAt   DateTime @default(now())

  trainerSkills TrainerSkill[]
  requestSkills JobRequestSkill[]

  @@index([category])
}

model TrainerSkill {
  id              String  @id @default(cuid())
  profileId       String
  skillId         String
  level           String? // BEGINNER | INTERMEDIATE | ADVANCED | EXPERT
  yearsExperience Int?

  profile TrainerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([profileId, skillId])
}

// =========================
// Job Requests & Applications
// =========================

enum JobRequestStatus {
  DRAFT
  OPEN
  IN_REVIEW
  CLOSED
  ARCHIVED
}

enum WorkType {
  REMOTE
  ONSITE
  HYBRID
}

enum ConfidentialityLevel {
  LOW
  MEDIUM
  HIGH
}

model JobRequest {
  id                   String               @id @default(cuid())
  companyId            String
  modelConnectionId    String?
  slug                 String               @unique
  title                String
  description          String
  objective            String?
  modelFamily          String?
  industry             String?
  languages            String[]             @default([])
  durationDays         Int?
  budgetMin            Int?
  budgetMax            Int?
  currency             String               @default("USD")
  workType             WorkType             @default(REMOTE)
  confidentialityLevel ConfidentialityLevel @default(LOW)
  status               JobRequestStatus     @default(DRAFT)
  featured             Boolean              @default(false)
  publishedAt          DateTime?
  closedAt             DateTime?
  applicationSchema    Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  modelConnection ModelConnection?     @relation(fields: [modelConnectionId], references: [id], onDelete: SetNull)
  skills          JobRequestSkill[]
  questions       JobRequestQuestion[]
  applications    Application[]
  tests           Test[]
  conversations   Conversation[]
  modelCalls      ModelCall[]

  @@index([status, publishedAt])
  @@index([companyId])
  @@index([modelConnectionId])
}

model JobRequestSkill {
  id        String  @id @default(cuid())
  requestId String
  skillId   String
  required  Boolean @default(true)
  minYears  Int?

  request JobRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  skill   Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([requestId, skillId])
}

model JobRequestQuestion {
  id        String   @id @default(cuid())
  requestId String
  prompt    String
  type      String   @default("TEXT") // TEXT | MCQ | MULTI | SCALE
  options   String[] @default([])
  required  Boolean  @default(false)
  order     Int      @default(0)

  request JobRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  TEST_ASSIGNED
  TEST_SUBMITTED
  INTERVIEW
  OFFERED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model Application {
  id                   String            @id @default(cuid())
  requestId            String
  trainerId            String
  status               ApplicationStatus @default(APPLIED)
  coverLetter          String?
  proposedRate         Int?
  proposedTimelineDays Int?
  matchScore           Float?
  answers              Json              @default("{}")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  request     JobRequest              @relation(fields: [requestId], references: [id], onDelete: Cascade)
  trainer     User                    @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  attempts    TestAttempt[]
  attachments ApplicationAttachment[]
  modelCalls  ModelCall[]
  contracts   Contract[]

  @@unique([requestId, trainerId])
  @@index([trainerId])
}

model ApplicationAttachment {
  id            String    @id @default(cuid())
  applicationId String
  objectKey     String    @unique
  mimeType      String
  byteLength    Int
  title         String?
  scanStatus    String    @default("pending") // pending | clean | infected
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, deletedAt])
}

// =========================
// Tests
// =========================

enum TestScoringMode {
  AUTO
  MANUAL
  HYBRID
}

model Test {
  id           String          @id @default(cuid())
  requestId    String?
  title        String
  description  String?
  timeLimitMin Int?
  passingScore Int             @default(60)
  scoringMode  TestScoringMode @default(AUTO)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  request  JobRequest?   @relation(fields: [requestId], references: [id], onDelete: SetNull)
  tasks    TestTask[]
  attempts TestAttempt[]
}

model TestTask {
  id        String   @id @default(cuid())
  testId    String
  prompt    String
  type      String   @default("MCQ") // MCQ | TEXT | CODE | PROMPT_TUNE | LABEL | LIVE_PROMPT | WORKFLOW
  options   String[] @default([])
  answerKey String? // For MCQ / LABEL
  maxScore  Int      @default(10)
  rubric    Json?
  order     Int      @default(0)

  test      Test               @relation(fields: [testId], references: [id], onDelete: Cascade)
  responses TestTaskResponse[]
}

enum TestAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  EXPIRED
}

model TestAttempt {
  id             String            @id @default(cuid())
  testId         String
  applicationId  String?
  trainerId      String
  startedAt      DateTime          @default(now())
  submittedAt    DateTime?
  status         TestAttemptStatus @default(IN_PROGRESS)
  totalScore     Int?
  scoreBreakdown Json?
  durationSec    Int?
  reviewerNotes  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  test        Test               @relation(fields: [testId], references: [id], onDelete: Cascade)
  application Application?       @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  responses   TestTaskResponse[]

  @@unique([testId, trainerId, applicationId])
  @@index([trainerId])
}

model TestTaskResponse {
  id          String  @id @default(cuid())
  attemptId   String
  taskId      String
  response    Json
  autoScore   Int?
  manualScore Int?
  comments    String?

  attempt TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  task    TestTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([attemptId, taskId])
}

// =========================
// Collaboration
// =========================

model Conversation {
  id         String    @id @default(cuid())
  requestId  String?
  lockedAt   DateTime?
  lockedById String?
  lockReason String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  request      JobRequest?               @relation(fields: [requestId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([lockedAt])
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  archivedAt     DateTime?
  lastReadAt     DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  type           String    @default("TEXT") // TEXT | FILE | SYSTEM
  redactedAt     DateTime?
  redactedById   String?
  redactReason   String?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([redactedAt])
}

// =========================
// Reviews & Notifications
// =========================

/// A review left by one party of a contract about the other. We persist
/// `contractId` so we can show provenance ("Verified contract review") and
/// enforce one review per author per contract via the unique constraint.
model Review {
  id         String   @id @default(cuid())
  authorId   String
  targetId   String
  contractId String?
  projectRef String?
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  author   User      @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target   User      @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@unique([authorId, contractId])
  @@index([targetId])
  @@index([contractId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

// =========================
// Subscriptions & Ads
// =========================

enum PlanAudience {
  COMPANY
  TRAINER
}

model Plan {
  id            String       @id @default(cuid())
  audience      PlanAudience
  tier          String
  priceMonthly  Int
  priceYearly   Int
  featuresJson  Json
  stripePriceId String?
  createdAt     DateTime     @default(now())
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  planId               String
  status               String    @default("ACTIVE")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?   @unique
  stripeCustomerId     String?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// =========================
// Payments & Contracts (T4.C)
// =========================

enum StripeConnectStatus {
  NONE
  PENDING
  ACTIVE
  RESTRICTED
}

/// Per-trainer Stripe Express Connect account used to receive payouts
/// when milestones are released. Onboarding is initiated by the trainer
/// via an Account Link; status is synced from the `account.updated`
/// webhook (see `apps/api/src/payments/webhook.controller.ts`).
model StripeConnectAccount {
  id               String              @id @default(cuid())
  userId           String              @unique
  stripeAccountId  String              @unique
  status           StripeConnectStatus @default(PENDING)
  chargesEnabled   Boolean             @default(false)
  payoutsEnabled   Boolean             @default(false)
  detailsSubmitted Boolean             @default(false)
  country          String?
  defaultCurrency  String?
  lastSyncedAt     DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ContractStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
  DISPUTED
}

enum MilestoneStatus {
  PENDING
  FUNDED
  RELEASED
  REFUNDED
  CANCELLED
}

enum PaymentIntentStatus {
  REQUIRES_PAYMENT_METHOD
  REQUIRES_CONFIRMATION
  REQUIRES_ACTION
  PROCESSING
  REQUIRES_CAPTURE
  SUCCEEDED
  CANCELED
  FAILED
}

enum PayoutStatus {
  PENDING
  IN_TRANSIT
  PAID
  FAILED
  CANCELLED
}

/// A binding agreement between a company and trainer derived from an
/// accepted application. Composed of one or more milestones that move
/// money through escrow (PaymentIntent → held on platform → Transfer to
/// Connect account on release).
model Contract {
  id               String         @id @default(cuid())
  applicationId    String
  companyId        String
  trainerId        String
  title            String
  description      String?
  currency         String         @default("USD")
  totalAmountCents Int
  platformFeeBps   Int            @default(1000) // 10% default commission
  status           ContractStatus @default(DRAFT)
  acceptedAt       DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trainer     User        @relation("ContractTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  milestones  Milestone[]
  reviews     Review[]
  disputes    Dispute[]

  @@index([companyId, status])
  @@index([trainerId, status])
  @@index([applicationId])
}

/// Lifecycle of a dispute raised on a contract.
/// OPEN: just raised, awaiting admin triage.
/// UNDER_REVIEW: admin is actively investigating.
/// RESOLVED_FOR_TRAINER / RESOLVED_FOR_COMPANY: admin sided with one party.
/// REJECTED: dispute determined to be without merit.
/// WITHDRAWN: raiser cancelled before admin acted.
enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_FOR_TRAINER
  RESOLVED_FOR_COMPANY
  REJECTED
  WITHDRAWN
}

enum DisputePartyRole {
  COMPANY
  TRAINER
}

/// A formal dispute on a contract. Either party can raise one; admin
/// resolves it. We keep a single OPEN/UNDER_REVIEW row per contract via
/// a partial unique index in code (enforced at the service layer; SQL
/// supports it but Prisma does not surface partial-unique syntax).
model Dispute {
  id           String           @id @default(cuid())
  contractId   String
  raisedById   String
  raisedByRole DisputePartyRole
  reason       String
  description  String?
  evidence     Json?
  status       DisputeStatus    @default(OPEN)
  resolverId   String?
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  raisedBy User     @relation("DisputeRaiser", fields: [raisedById], references: [id], onDelete: Cascade)
  resolver User?    @relation("DisputeResolver", fields: [resolverId], references: [id], onDelete: SetNull)

  @@index([contractId, status])
  @@index([status, createdAt])
  @@index([raisedById])
}

/// An individual payment milestone within a contract. State machine:
/// PENDING → FUNDED (PaymentIntent succeeded, money held on platform)
/// → RELEASED (Transfer to trainer Connect account + Payout queued)
/// OR → REFUNDED (funds returned to company).
model Milestone {
  id          String          @id @default(cuid())
  contractId  String
  title       String
  description String?
  amountCents Int
  order       Int             @default(0)
  dueDate     DateTime?
  status      MilestoneStatus @default(PENDING)
  fundedAt    DateTime?
  releasedAt  DateTime?
  refundedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  contract       Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  paymentIntents PaymentIntent[]
  payouts        Payout[]

  @@index([contractId, order])
}

/// Tracks a Stripe PaymentIntent used to fund a milestone. Mirrors
/// Stripe state via webhooks; idempotent by `stripePaymentIntentId`.
model PaymentIntent {
  id                    String              @id @default(cuid())
  milestoneId           String
  stripePaymentIntentId String              @unique
  clientSecret          String?
  amountCents           Int
  currency              String              @default("USD")
  status                PaymentIntentStatus @default(REQUIRES_PAYMENT_METHOD)
  receiptUrl            String?
  failureMessage        String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
}

/// A transfer from the platform to a trainer's Connect account when a
/// milestone is released. Mirrors Stripe Transfer state via webhooks.
model Payout {
  id               String       @id @default(cuid())
  userId           String
  milestoneId      String?
  stripeTransferId String?      @unique
  stripePayoutId   String?      @unique
  amountCents      Int
  currency         String       @default("USD")
  status           PayoutStatus @default(PENDING)
  failureMessage   String?
  arrivedAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestone Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([milestoneId])
}

/// Idempotency store for incoming Stripe webhook events — every
/// handled event id is recorded so replays become no-ops.
model StripeWebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique
  type          String
  processedAt   DateTime?
  errorMessage  String?
  payload       Json
  createdAt     DateTime  @default(now())

  @@index([type, createdAt])
}

enum AdCampaignStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  ACTIVE
  PAUSED
  REJECTED
  ENDED
}

enum AdPricingModel {
  CPM
  CPC
  FLAT
}

enum AdPlacement {
  HOMEPAGE_HERO
  SIDEBAR_SEARCH
  FEATURED_TRAINER
  FEATURED_COMPANY
  SEARCH_RESULT
  CATEGORY_SPONSOR
  NEWSLETTER
  NATIVE_LISTING
}

enum AdCreativeType {
  BANNER
  SPONSORED_LISTING
  FEATURED_TRAINER
  CATEGORY_SPONSOR
  NATIVE
}

enum AdTopupStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// Why a campaign entered the PAUSED state. Used by creditBudget() to decide
// whether a successful top-up should auto-resume the campaign: only the
// BUDGET_EXHAUSTED auto-pause is safe to reverse, manual admin/owner pauses
// must stay paused until explicitly resumed.
enum AdPauseReason {
  BUDGET_EXHAUSTED
  ADMIN
  OWNER
}

model AdCampaign {
  id                 String           @id @default(cuid())
  ownerId            String
  companyId          String?
  name               String
  pricingModel       AdPricingModel   @default(CPM)
  // Unit prices in the smallest currency unit (cents). Exactly one is required
  // based on `pricingModel`; see `ads.service#create`.
  cpmCents           Int?
  cpcCents           Int?
  flatFeeCents       Int?
  // Running totals — kept on the row so serve() can enforce budget cheaply
  // (no aggregate query per request).
  budgetCents        Int              @default(0)
  // Spent-to-date in whole cents (display-facing, floor of the microcent
  // accumulator) and in microcents (1/1000 of a cent) for lossless sub-cent
  // CPM accrual. CPM charges are fractional per impression, so the sub-cent
  // accumulator prevents Math.floor(cpmCents/1000) from zeroing out for every
  // rate below $10 / 1000 (e.g. cpmCents=500 → 500 microcents/impression).
  spentCents         Int              @default(0)
  spentMicroCents    BigInt           @default(0)
  status             AdCampaignStatus @default(DRAFT)
  pausedReason       AdPauseReason?
  rejectionReason    String?
  reviewedById       String?
  reviewedAt         DateTime?
  targetingCountries String[]         @default([])
  targetingLocales   String[]         @default([])
  targetingSkillIds  String[]         @default([])
  // Hard cap of impressions charged per `sessionHash` within 24h window.
  frequencyCapPerDay Int?
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  owner       User           @relation("AdCampaignOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  reviewer    User?          @relation("AdCampaignReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  company     Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  creatives   AdCreative[]
  impressions AdImpression[]
  clicks      AdClick[]
  topups      AdTopup[]

  @@index([ownerId])
  @@index([status])
  @@index([companyId])
}

model AdCreative {
  id              String         @id @default(cuid())
  campaignId      String
  type            AdCreativeType @default(NATIVE)
  assetUrl        String?
  headline        String
  body            String?
  ctaLabel        String?
  ctaUrl          String
  placements      AdPlacement[]  @default([])
  weight          Int            @default(1)
  isActive        Boolean        @default(true)
  impressionCount Int            @default(0)
  clickCount      Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  campaign    AdCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  impressions AdImpression[]
  clicks      AdClick[]

  @@index([campaignId])
}

model AdImpression {
  id           String      @id @default(cuid())
  creativeId   String
  campaignId   String
  placement    AdPlacement
  locale       String?
  country      String?
  sessionHash  String?
  userId       String?
  chargedCents Int         @default(0)
  createdAt    DateTime    @default(now())

  creative AdCreative @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([creativeId, createdAt])
  @@index([campaignId, createdAt])
  @@index([sessionHash, createdAt])
}

model AdClick {
  id           String      @id @default(cuid())
  creativeId   String
  campaignId   String
  placement    AdPlacement
  locale       String?
  country      String?
  sessionHash  String?
  userId       String?
  chargedCents Int         @default(0)
  createdAt    DateTime    @default(now())

  creative AdCreative @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([creativeId, createdAt])
  @@index([campaignId, createdAt])
}

model AdTopup {
  id                    String        @id @default(cuid())
  campaignId            String
  amountCents           Int
  currency              String        @default("usd")
  stripePaymentIntentId String?       @unique
  status                AdTopupStatus @default(PENDING)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

// =========================
// CMS & Settings
// =========================

model Page {
  id              String   @id @default(cuid())
  slug            String
  locale          String
  title           String
  content         String
  metaTitle       String?
  metaDescription String?
  status          String   @default("PUBLISHED")
  /// Optional tag — e.g. "LEGAL" for /terms, /privacy (hidden from marketing nav).
  kind            String   @default("PAGE")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([slug, locale])
  @@index([kind, status])
}

model Setting {
  key         String   @id
  value       Json
  group       String   @default("general")
  /// When true, the key + value is exposed via `/public/settings` for the marketing
  /// site and client layout (branding, locales, currencies). Admin-only keys (API
  /// credentials, fee basis points, etc.) must keep this `false`.
  isPublic    Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@index([group])
  @@index([isPublic])
}

// =========================
// CMS — blog + FAQ + feature flags
// =========================

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Category {
  id            String    @id @default(cuid())
  slug          String    @unique
  nameEn        String
  nameAr        String
  descriptionEn String?
  descriptionAr String?
  order         Int       @default(0)
  articles      Article[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Article {
  id              String        @id @default(cuid())
  slug            String
  locale          String
  title           String
  excerpt         String?
  content         String
  coverUrl        String?
  metaTitle       String?
  metaDescription String?
  status          ArticleStatus @default(DRAFT)
  publishedAt     DateTime?
  categoryId      String?
  category        Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  authorId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([slug, locale])
  @@index([status, publishedAt])
  @@index([categoryId])
}

model FaqEntry {
  id        String   @id @default(cuid())
  locale    String
  section   String   @default("GENERAL")
  question  String
  answer    String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale, section, order])
  @@index([published])
}

model FeatureFlag {
  key         String   @id
  description String?
  enabled     Boolean  @default(false)
  /// JSON payload with optional variants / rollout percentage / audiences.
  payload     Json?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

// =========================
// Verification (trainers + companies)
// =========================

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationTargetType {
  COMPANY
  TRAINER
}

model VerificationRequest {
  id              String                 @id @default(cuid())
  submitterId     String
  targetType      VerificationTargetType
  targetId        String
  status          VerificationStatus     @default(PENDING)
  documents       Json                   @default("[]")
  notes           String?
  reviewerId      String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  submitter User  @relation("VerificationSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  reviewer  User? @relation("VerificationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([submitterId])
}

// =========================
// Moderation (reports & resolution)
// =========================

enum ReportTargetType {
  USER
  COMPANY
  TRAINER
  REQUEST
  APPLICATION
  MESSAGE
  CONVERSATION
  REVIEW
  TEST
  OTHER
}

enum ReportCategory {
  SPAM
  HARASSMENT
  INAPPROPRIATE
  FRAUD
  IMPERSONATION
  COPYRIGHT
  SAFETY
  OTHER
}

enum ReportStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  DISMISSED
}

enum ReportResolution {
  NO_ACTION
  WARNING_ISSUED
  CONTENT_REMOVED
  USER_SUSPENDED
  USER_BANNED
  ESCALATED
}

model Report {
  id            String            @id @default(cuid())
  reporterId    String
  targetType    ReportTargetType
  targetId      String
  category      ReportCategory
  reason        String
  evidenceUrls  String[]          @default([])
  status        ReportStatus      @default(OPEN)
  resolution    ReportResolution?
  resolverId    String?
  resolvedAt    DateTime?
  resolverNotes String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  reporter User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver User? @relation("ReportResolver", fields: [resolverId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId])
}

/// Admin-editable email templates. The in-code templates in
/// `apps/api/src/email/templates/*` remain as fallback so the app always
/// has content even before the DB is seeded. On every email send, the
/// service looks up `(key, locale)` here first; if found and enabled, the
/// DB row wins and `{{variables}}` are interpolated against the call-site
/// params. Otherwise we fall back to the built-in template.
///
/// `key` matches the enum in @trainova/shared (VERIFY_EMAIL, RESET_PASSWORD,
/// WELCOME, TEST_ASSIGNED, …) and `locale` is 'en' or 'ar'. Composite unique
/// on (key, locale) enforces exactly one row per translation.
model EmailTemplate {
  id          String   @id @default(cuid())
  key         String
  locale      String
  subject     String
  bodyHtml    String   @db.Text
  bodyText    String   @db.Text
  variables   Json     @default("[]")
  enabled     Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("EmailTemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([key, locale])
  @@index([key])
}

/// FX rate snapshot used to convert one currency to another for *display*
/// purposes. Authoritative monetary records stay in the contract/payout's
/// own currency. Rates are sourced from the ECB's Frankfurter mirror
/// (https://api.frankfurter.app), which is free, key-less, and updates
/// daily on TARGET2 settlement days. We always store rates anchored to
/// USD so all formatters can do exactly two lookups (from→USD, USD→to)
/// and avoid an N×N rate matrix.
///
/// Composite unique on (base, quote, fetchedAt::date) is enforced via a
/// partial unique index in the migration; Prisma stores the latest rate
/// per pair on the lookup index `(base, quote, fetchedAt desc)`.
model ExchangeRate {
  id        String   @id @default(cuid())
  base      String // ISO 4217 (always "USD" for now)
  quote     String // ISO 4217 (e.g. "EUR", "SAR", "GBP")
  rate      Decimal  @db.Decimal(18, 8)
  source    String   @default("frankfurter")
  fetchedAt DateTime @default(now())

  @@index([base, quote, fetchedAt(sort: Desc)])
}
