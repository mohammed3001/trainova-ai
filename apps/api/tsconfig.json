{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "types": ["node"],
    "baseUrl": "./",
    "paths": {
      "@trainova/db": ["../../packages/db/src"],
      "@trainova/shared": ["../../packages/shared/src"]
    }
  },
  "include": ["src/**/*"]
}
