# Database
DATABASE_URL="postgresql://trainova:trainova@localhost:5432/trainova?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# API
API_PORT=4000
API_URL="http://localhost:4000"
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="14d"
JWT_REFRESH_TTL="30d"

# Web
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Stripe (stub for MVP)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email
# EMAIL_PROVIDER: "console" (default; logs only) or "resend" (production).
# Dev/CI stays on "console" so no external calls happen during the golden E2E.
EMAIL_PROVIDER="console"
RESEND_API_KEY=""
EMAIL_FROM="Trainova AI <no-reply@trainova.ai>"

# AI provider (optional in MVP)
AI_PROVIDER="mock"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Symmetric wrapping key for secrets stored at rest (model provider API
# keys, OAuth refresh tokens, webhook secrets, etc.). Generate once per
# environment and keep it identical across rolling deploys so existing
# rows remain decryptable:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=""

# Storage (S3-compatible)
# Legacy single-bucket env (unused by the uploads module; kept until old
# references are removed).
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Object storage (uploads module — Tier 1.E)
# When these are empty the uploads module runs in a stub mode that never
# touches the network; the API surface is identical so local/CI work without
# real credentials. Populate for staging/production.
OBJECT_STORAGE_ENDPOINT=""
OBJECT_STORAGE_REGION="auto"
OBJECT_STORAGE_BUCKET_PUBLIC="trainova-public"
OBJECT_STORAGE_BUCKET_PRIVATE="trainova-private"
OBJECT_STORAGE_PUBLIC_BASE_URL=""
OBJECT_STORAGE_ACCESS_KEY_ID=""
OBJECT_STORAGE_SECRET_ACCESS_KEY=""
